    "vue-i18n": "^11.4.4",
    "vue-router": "^4.6.4",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
